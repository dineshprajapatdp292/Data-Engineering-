class Solution:
def isPalindrome(self, s: str) -> bool:

    cleaned = ''
    
    for ch in s:
        if ch.isalnum():
            cleaned += ch.lower()
    
    def f(i):
        if i >= len(cleaned)//2:
            return True
        if cleaned[i] != cleaned[len(cleaned)-1-i]:
            return False
        return f(i+1)
    
    return f(0)
