class Solution:
def isValid(self, s: str) -> bool:

    x = []

    if len(s) % 2 != 0:
        return False

    for i in s:
        if i == "(" or i == "{" or i == "[":
            x.append(i)
        else:
            if len(x) == 0:
                return False
            elif (i == ")" and x[-1] == "(") or \
                 (i == "}" and x[-1] == "{") or \
                 (i == "]" and x[-1] == "["):
                x.pop()
            else:
                return False

    return len(x) == 0
