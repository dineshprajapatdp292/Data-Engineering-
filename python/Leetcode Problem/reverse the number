class Solution:
def reverse(self, x: int) -> int:
INT_MIN = -231
INT_MAX = 231 - 1

    rev = 0
    
    while x != 0:
        digit = int(x % 10)
        
        # Python negative modulo fix
        if x < 0 and digit > 0:
            digit -= 10
        
        x = (x - digit) // 10
        
        # Overflow check BEFORE multiplying
        if rev > INT_MAX // 10 or rev < INT_MIN // 10:
            return 0
        
        rev = rev * 10 + digit
    
    return rev
