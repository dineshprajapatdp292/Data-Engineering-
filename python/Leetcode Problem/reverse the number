class Solution:
def reverse(self, x: int) -> int:
INT_MIN = -231
INT_MAX = 231 - 1

    sign = -1 if x < 0 else 1
    
    # Reverse using string
    reversed_str = str(abs(x))[::-1]
    
    result = sign * int(reversed_str)
    
    # 32-bit range check
    if result < INT_MIN or result > INT_MAX:
        return 0
    
    return result
